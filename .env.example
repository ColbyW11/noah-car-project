# Copy to .env and fill in real values. Never commit .env.

# Path to the Google service account JSON file with Drive access.
VW_SCRAPER_SA_PATH=~/.config/vw-scraper/service_account.json

# ID of the root Drive folder for outputs.
# Find this in the Drive folder URL: drive.google.com/drive/folders/<THIS_PART>
VW_SCRAPER_DRIVE_FOLDER_ID=11T9gilRRAaMCTX4MTwkxGjcJ_X4I6HUI

# Optional: Slack webhook for failure alerts.
VW_SCRAPER_SLACK_WEBHOOK=

# Optional: override the default concurrency for the daily run.
VW_SCRAPER_CONCURRENCY=5

# Optional: override the scraper User-Agent. Must honestly identify the scraper.
VW_SCRAPER_USER_AGENT=vw-oil-tracker/0.1 (contact: you@example.com)
